{
  "compilerOptions": {
    "target": "ES2022",
    "rootDir": "./src/",
    "outDir": "./dist/",
    "noEmitOnError": true,
    "noEmitHelpers": true,
    "alwaysStrict": true,
    "allowJs": false,
    "disableSizeLimit": true,
    "allowSyntheticDefaultImports": true,
    "noImplicitAny": true
  },
  "include": ["./src/**/*"],
  "compileOnSave": true
}
